# Получить ключ: https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE

# Имя модели (опционально). По умолчанию agent.py использует gemini-3.1-flash-lite
# (500 запросов в день на free tier — больше всех других моделей).
# Раскомментируйте, чтобы переопределить:
# ADK_MODEL=gemini-2.5-flash         # 20 RPD, более мощная
# ADK_MODEL=gemini-2.5-flash-lite    # 20 RPD, легче
# ADK_MODEL=gemini-3-flash           # 20 RPD
# ADK_MODEL=gemma-4-31b              # 1500 RPD, open-weight
